# =============================================================================
# Zara Agent - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
#   cp .env.example .env
# =============================================================================

# --- Agent Identity ---
ZARA_AGENT_NAME=Zara
ZARA_AGENT_ROLE="Lead Engineering Orchestrator"
ZARA_AGENT_DESCRIPTION="AI-powered engineering leadership agent coordinating specialized sub-agents"

# --- User Identity ---
# How Zara addresses you. Optional — if unset, Zara auto-discovers your name from
# the runtime profile, semantic memory, git config, or your OS account (in that
# order). Set this to force a specific name/honorific (e.g. "mas Aldo").
ZARA_USER_NAME=

# --- Path Configuration ---
# Root directory for Zara runtime data (knowledge, skills, memory)
ZARA_HOME=~/.zara
# Override individual paths (optional - defaults resolve relative to ZARA_HOME)
ZARA_KNOWLEDGE_DIR=
ZARA_SKILLS_DIR=
ZARA_MEMORY_DIR=
ZARA_SESSIONS_DIR=

# --- API Keys ---
# Context7 API key for live documentation fetching
# Get one at: https://context7.com
CONTEXT7_API_KEY=

# --- LLM Configuration ---
# Default model for the orchestrator agent
ZARA_DEFAULT_MODEL=claude-sonnet-4-5
# Default model for swarm workers (cheaper for disposable tasks)
ZARA_WORKER_MODEL=deepseek/deepseek-v4-flash

# --- Feature Toggles ---
# Enable/disable features (true/false)
ZARA_ENABLE_MEMORY=true
ZARA_ENABLE_HIVEMIND=true
ZARA_ENABLE_SWARM=true
ZARA_ENABLE_SENIOR_DEV=true
ZARA_ENABLE_CONTEXT7=true
ZARA_ENABLE_SKILL_AUTO_CREATE=true

# --- Knowledge Base ---
# Path to DevIQ knowledge base (leave empty to skip)
DEVIQ_KNOWLEDGE_PATH=
# Number of articles in the knowledge base (for status display)
DEVIQ_KNOWLEDGE_COUNT=240
# Sections available in the knowledge base
DEVIQ_KNOWLEDGE_SECTIONS=antipatterns,architecture,code-smells,design-patterns,domain-driven-design,laws,practices,principles,terms,testing,tools,values

# --- Memory Configuration ---
ZARA_MEMORY_ENABLED=true
ZARA_MEMORY_JOURNAL_RETENTION_DAYS=365

# --- Session Configuration ---
ZARA_SESSION_AUTO_JOURNAL=true
ZARA_SESSION_LOG_FORMAT=markdown

# --- Security ---
# Comma-separated list of allowed command patterns (glob style)
ZARA_ALLOWED_COMMANDS=git,npm,npx,bun,python,pip,docker,kubectl,terraform,aws,gh
# Blocked command patterns (glob style)
ZARA_BLOCKED_COMMANDS=rm,-rf,chmod,chown,sudo
