# Zara Agent — Required Environment Variables
# Copy this to .env and fill in your values.
#
#   cp .env.example .env
#
# These are used by opencode and the MCP server.

# --- API Keys ---
# Your Anthropic API key for Claude models via Kiro
ANTHROPIC_API_KEY=sk-ant-...

# (Optional) Context7 API key for live documentation lookup
CONTEXT7_API_KEY=

# --- Identity ---
# Your name (used for personalization)
ZARA_USER_NAME=Aldo Karendra
