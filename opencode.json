{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-3-5-haiku-20241022",
  "autoupdate": true,
  "instructions": [
    "prompts/system.md",
    "prompts/philosophy.md",
    "knowledge/SUMMARY.md"
  ],
  "agent": {
    "build": {
      "description": "Zara — senior engineering partner, warm and ambitious, speaks your language naturally",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:.opencode/agent/zara.md}",
      "temperature": 0.3
    },
    "plan": {
      "description": "Zara plan agent — analysis and architecture without changes",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:.opencode/agent/plan.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      }
    },
    "architect": {
      "description": "Architecture specialist — system design, patterns, tradeoffs",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:.opencode/agent/architect.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "code-reviewer": {
      "description": "Code review specialist — quality, smells, refactoring suggestions",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:.opencode/agent/code-reviewer.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "testing-lead": {
      "description": "Testing specialist — strategy, coverage, test design",
      "mode": "subagent",
      "prompt": "{file:.opencode/agent/testing-lead.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "security-reviewer": {
      "description": "Security specialist — threat modeling, secure design, auth patterns",
      "mode": "subagent",
      "prompt": "{file:.opencode/agent/security-reviewer.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "delivery-lead": {
      "description": "Delivery specialist — shipping, velocity, tech debt management",
      "mode": "subagent",
      "prompt": "{file:.opencode/agent/delivery-lead.md}",
      "temperature": 0.3
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:CONTEXT7_API_KEY}"
      }
    }
  },
  "permission": {
    "bash": "ask"
  }
}
