{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "zara",
  "autoupdate": true,
  "instructions": [
    ".opencode/instructions/system.md",
    "prompts/philosophy.md"
  ],
  "agent": {
    "zara": {
      "description": "Zara — senior engineering partner, warm and ambitious, speaks your language naturally",
      "mode": "primary",

      "prompt": "{file:.opencode/agent/zara.md}",
      "temperature": 0.3
    },
    "plan": {
      "description": "Sketch — Zara's planning mode, analysis and design without changes",
      "mode": "primary",

      "prompt": "{file:.opencode/agent/sketch.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "patch": false
      }
    },
    "architect": {
      "description": "Atlas — architecture specialist, system design, patterns, tradeoffs",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/atlas.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "code-reviewer": {
      "description": "Lens — code review specialist, quality, smells, refactoring",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/lens.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "testing-lead": {
      "description": "Probe — testing specialist, strategy, coverage, test design",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/probe.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "security-reviewer": {
      "description": "Shield — security specialist, threat modeling, secure design, auth",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/shield.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "delivery-lead": {
      "description": "Pulse — delivery specialist, shipping, velocity, tech debt",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/pulse.md}",
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "swarm": {
      "description": "Hive — swarm coordinator, decomposes, delegates, synthesizes",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/hive.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "loop-engineer": {
      "description": "Rhythm — loop engineering partner, iterative workflows, verification, failure modes",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/rhythm.md}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    },
    "implementation": {
      "description": "Forge — implementation specialist, plan → code → verify → ship. Execution-focused.",
      "mode": "subagent",

      "prompt": "{file:.opencode/agent/forge.md}",
      "temperature": 0.2
    }
  },
  "command": {
    "audit": {
      "template": "{file:.opencode/commands/audit.md}"
    },
    "auto": {
      "template": "{file:.opencode/commands/auto.md}"
    },
    "decide": {
      "template": "{file:.opencode/commands/decide.md}",
      "agent": "architect"
    },
    "focus": {
      "template": "{file:.opencode/commands/focus.md}"
    },
    "goal": {
      "template": "{file:.opencode/commands/goal.md}"
    },
    "handoff": {
      "template": "{file:.opencode/commands/handoff.md}"
    },
    "install": {
      "template": "{file:.opencode/commands/install.md}"
    },
    "loop": {
      "template": "{file:.opencode/commands/loop.md}"
    },
    "music": {
      "template": "{file:.opencode/commands/music.md}"
    },
    "resume": {
      "template": "{file:.opencode/commands/resume.md}"
    },
    "review": {
      "template": "{file:.opencode/commands/review.md}",
      "agent": "code-reviewer"
    },
    "shutdown": {
      "template": "{file:.opencode/commands/shutdown.md}"
    },
    "standup": {
      "template": "{file:.opencode/commands/standup.md}"
    },
    "swarm": {
      "template": "{file:.opencode/commands/swarm.md}",
      "agent": "swarm"
    },
    "think": {
      "template": "{file:.opencode/commands/think.md}"
    },
    "code": {
      "template": "{file:.opencode/commands/code.md}"
    },
    "zara": {
      "template": "{file:.opencode/commands/zara.md}"
    }
  },
  "plugin": [
    ".opencode/plugin/zara.mjs"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:CONTEXT7_API_KEY}"
      }
    },
    "Orchestrator": {
      "type": "local",
      "command": [
        "node",
        "tools/mcp/index.mjs"
      ],
      "timeout": 5000,
      "enabled": true
    }
  },
  "permission": {
    "bash": "allow"
  }
}
